        <div class="glass-panel rounded-2xl max-w-2xl w-full max-h-[90vh] overflow-y-auto border border-cyan-500/30 glow-box transform scale-95 opacity-0 transition-all duration-300" id="modal-content">
            <div class="p-6 border-b border-cyan-900/30 flex justify-between items-center">
                <h2 class="text-2xl font-tech text-cyan-400">LAPORAN PENILANGAN</h2>
                <button onclick="closeModal()" class="text-gray-500 hover:text-white transition-colors">
                    <i class="fas fa-times text-xl"></i>
