                        </div>
                        <div class="p-2 rounded bg-red-900/20 border border-red-500/30 text-red-400">
                            <div class="font-bold mb-1">BERAT</div>
                            <div class="text-[10px] opacity-70">Hukuman Berat</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

